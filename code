double gstbill(double bill){
        double gst;
    	gst=bill*18/100;
	    return gst;
	
}
double electricyduty(double bill){
	    double duty;
	    duty=(bill*1.5/100);
	    return duty;
	
}
double incometax(double bill , int type){
	   double household,commercial,tax;
	      if (type==household){
		     tax=(bill*10/100);
       	 }else if(type==commercial){
		     tax=(bill*15/100);
       	 }
	    return tax;
}
